<UserControl x:Class="CombasLauncherApp.UI.Pages.BuildManagerPage.BuildManagerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CombasLauncherApp.UI.Pages.BuildManagerPage"
             xmlns:models="clr-namespace:CombasLauncherApp.Models"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:DataContext="{d:DesignInstance local:BuildManagerPageViewModel}">
    
    <UserControl.Resources>
        <system:Double x:Key="FontSize">14</system:Double>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Left Side (Build Collections)-->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Column="0" Grid.Row="0" Background="{StaticResource OverlayBackground}" Margin="0,10,5,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Background="{StaticResource ButtonHoverBrush}">
                    <TextBlock Text="Build Collections" FontWeight="Bold" FontSize="{StaticResource FontSize}" Margin="10,2"/>
                </Grid>
                <ItemsControl Grid.Row="1" ItemsSource="{Binding BuildCollections}" Margin="5">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Header="{Binding }" IsExpanded="False" Margin="0,5,0,0">
                                <Expander.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,5,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" FontSize="{StaticResource FontSize}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Builds.Count, StringFormat={}{0} / 50}" FontWeight="Bold" FontSize="{StaticResource FontSize}" VerticalAlignment="Center" Margin="5,0"/>
                                            <Button Grid.Column="2" Content="{StaticResource LOC_Delete}" FontWeight="Bold"
                                                    Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=DataContext.DeleteCollectionCommand}"
                                                    CommandParameter="{Binding}" Padding="8"/>
                                        </Grid>
                                    </DataTemplate>
                                </Expander.HeaderTemplate>
                                <ListBox ItemsSource="{Binding Builds}" 
                                         SelectedItem="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=DataContext.SelectedCollectionBuild, Mode=TwoWay}" 
                                         Margin="5"
                                         AllowDrop="True"
                                         Background="Transparent"
                                         BorderThickness="0" HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid >
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="{StaticResource FontSize}" FontWeight="Bold" Margin="0,0,5,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding BuildDate}" FontSize="{StaticResource FontSize}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
            <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Margin="10">
                <TextBox x:Name="CreateCollectionNameBox" Width="200" Margin="0,0,10,0" />
                <Button Content="{StaticResource LOC_Create}"
                        Command="{Binding CreateCollectionCommand}"
                        CommandParameter="{Binding Text, ElementName=CreateCollectionNameBox}" />
             
            </StackPanel>
                    
        </Grid>
        <!-- Center (Images) -->
        <Grid Grid.Column="1" >
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="20"/>
                <RowDefinition/>
            </Grid.RowDefinitions> 
       
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Viewbox Width="40" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="40" Height="80">
                        <Path Stroke="{StaticResource ButtonHoverBrush}" StrokeThickness="0" Fill="{StaticResource ButtonHoverBrush}"
                              Data="M5,10 L20,10 L20,70 L5,70 L0,40 Z"/>
                    </Canvas>
                </Viewbox>
                <Border Grid.Column="1" Grid.Row="0" Background="{StaticResource OverlayBackground}" BorderThickness="2" BorderBrush="{StaticResource ButtonHoverBrush}" Margin="0,10">
                    <Image Source="{Binding SelectedCollectionBuild.Image, FallbackValue='Resources/OopsImage.png'}" /> 
                </Border>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="10"/>
                </Grid.ColumnDefinitions>
                <Viewbox Grid.Column="0" Width="40" Grid.Row="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" >
                    <Canvas Width="40" Height="80">
                        <Path Stroke="{StaticResource ButtonHoverBrush}" StrokeThickness="0" Fill="{StaticResource ButtonHoverBrush}"
                              Data="M75,10 L60,10 L60,70 L75,70 L80,40 Z"/>
                    </Canvas>
                </Viewbox>
                <Border Grid.Column="0" Grid.Row="0" Background="{StaticResource OverlayBackground}" BorderThickness="2" BorderBrush="{StaticResource ButtonHoverBrush}" Margin="0,10">
                    <Image Source="{Binding SelectedLoadedBuild.Image, FallbackValue='Resources/OopsImage.png'}" />
                </Border>
                </Grid>
        </Grid>
      
        <!-- Right Side (Loaded Builds) -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical"  Background="{StaticResource OverlayBackground}" Margin="5,10,0,10">
                <Grid Background="{StaticResource ButtonHoverBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Loaded Builds" FontWeight="Bold" FontSize="{StaticResource FontSize}" Margin="10,2"/>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentLoadedBuilds.Count, StringFormat={}{0} / 50}" FontWeight="Bold" FontSize="{StaticResource FontSize}" Margin="10,2"/>
                </Grid>
                <ListBox ItemsSource="{Binding CurrentLoadedBuilds}" 
                         SelectedItem="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}, Path=DataContext.SelectedLoadedBuild, Mode=TwoWay}" 
                         Margin="5"
                         AllowDrop="True"
                         Background="Transparent"
                         BorderThickness="0" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="{StaticResource FontSize}" FontWeight="Bold" Margin="0,0,5,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding BuildDate}" FontSize="{StaticResource FontSize}" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>


            </StackPanel>
           

        </Grid>
    </Grid>
</UserControl>
